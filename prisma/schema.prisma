generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum ImmigrationStatus {
  citizen
  permanent_resident
  work_permit
  student_visa
  refugee
  asylum_seeker
  undocumented
  unknown
}

enum AgeBand {
  AGE_0_17
  AGE_18_25
  AGE_26_35
  AGE_36_45
  AGE_46_55
  AGE_56_64
  AGE_65_PLUS
}

enum EmploymentStatus {
  student
  employed
  self_employed
  unemployed
  retiree
}

enum BenefitsStatus {
  yes
  no
  unknown
}

enum IncomeBand {
  low
  medium
  high
  prefer_not_to_say
}

enum MetalTier {
  bronze
  silver
  gold
  platinum
}

enum PlanType {
  HMO
  PPO
  EPO
}

enum SpecialCategory {
  refugee
  temp_foreign_worker
  intl_student
  asylum_seeker
}

model User {
  id            String          @id @default(cuid())
  name          String?
  email         String?         @unique
  emailVerified DateTime?
  image         String?
  passwordHash  String?
  accounts      Account[]
  sessions      Session[]
  profile          Profile?
  medicalProfile   MedicalProfile?
  memories         UserMemory[]
  consentLogs      ConsentLog[]
  authenticators   Authenticator[]
  chatConversations ChatConversation[]
  coverageScores   CoverageScore[]
  lifeEvents       LifeEvent[]
  medicalShareLinks MedicalShareLink[]
  notifications    Notification[]
  passwordResetTokens PasswordResetToken[]
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  @@map("users")
}

model Account {
  userId             String
  type               String
  provider           String
  providerAccountId  String
  refresh_token      String?
  access_token       String?
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String?
  session_state      String?
  refresh_token_expires_in Int?
  user               User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@id([provider, providerAccountId])
  @@index([userId])
  @@map("accounts")
}

model Session {
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@id([sessionToken])
  @@index([userId])
  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@id([identifier, token])
  @@unique([token])
  @@map("verification_tokens")
}

model Authenticator {
  credentialID         String
  userId               String
  providerAccountId    String
  credentialPublicKey  String
  counter              Int
  credentialDeviceType String
  credentialBackedUp   Boolean
  transports           String?
  user                 User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([userId, credentialID])
  @@unique([credentialID])
  @@map("authenticators")
}

model Profile {
  id                  String            @id @default(cuid())
  userId              String            @unique
  province            String            @default("unknown")
  immigrationStatus   ImmigrationStatus @default(unknown)
  residencyStartDate  String            @default("unknown")
  ageBand             AgeBand           @default(AGE_18_25)
  employmentStatus    EmploymentStatus  @default(unemployed)
  hasEmployerBenefits BenefitsStatus    @default(unknown)
  dependants          Json
  incomeBand          IncomeBand        @default(prefer_not_to_say)
  specialCategory     SpecialCategory?
  language            String            @default("en")
  user                User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt

  @@map("profiles")
}

model ConsentLog {
  id        String   @id @default(cuid())
  userId    String
  action    String
  metadata  Json?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@map("consent_log")
}

model Plan {
  id                String    @id @default(cuid())
  planCode          String    @unique
  name              String
  carrier           String
  state             String
  metalTier         MetalTier
  planType          PlanType
  source            String    @default("manual")   // e.g. "sunlife", "manulife", "bluecross", "manual"
  type              String    @default("private")   // e.g. "provincial", "federal", "private", "employer"
  monthlyPremium    Int
  annualDeductible  Int       @default(0)
  deductible        Int                             // kept for backwards compat
  maxOutOfPocket    Int
  outOfPocketMax    Int       @default(0)
  coinsuranceRate   Int
  primaryCareCopay  Int
  specialistCopay   Int
  erCopay           Int       @default(0)
  drugCoverage      Json?                           // { formularyTier, brandCopay, genericCopay, specialtyCopay, ... }
  coverageDetails   Json?                           // { dental, vision, mental, physio, ... }
  eligibility       Json?                           // { provinces, immigrationStatuses, ageBands, ... }
  features          Json?                           // ML feature vectors for recommendation engine
  rawData           Json?                           // Original ingested data before normalization
  formulary         Json
  providerNetwork   Json
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  @@index([state, metalTier])
  @@index([carrier, state])
  @@index([source])
  @@index([type])
  @@map("plans")
}

model ExtractedPlan {
  id                   String    @id @default(cuid())
  sourceFile           String    @unique
  planName             String
  planType             String
  carrier              String
  jurisdiction         String
  extractedData        Json      // Full ExtractedPlanData from LLM
  mlFeatures           Json      // Full PlanMlFeatures with feature vector
  extractionConfidence String    @default("medium")
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  @@index([planType, jurisdiction])
  @@index([carrier])
  @@map("extracted_plans")
}

model MedicalProfile {
  id              String   @id @default(cuid())
  userId          String   @unique
  conditions      Json     // Array of diagnosed conditions
  medications     Json     // Array of current medications
  allergies       Json     // Array of known allergies
  surgeries       Json     // Array of past surgeries
  familyHistory   Json     // Array of family medical history items
  immunizations   Json     // Array of immunization records
  labResults      Json     // Array of lab/test results
  riskFactors     Json     // Array of lifestyle/genetic risk factors
  rawDocumentIds  String[] // IDs of source documents used for extraction
  confidence      Float    @default(0)
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  lastUpdated     DateTime @default(now())
  createdAt       DateTime @default(now())

  @@map("medical_profiles")
}

model UserMemory {
  id              String   @id @default(cuid())
  userId          String
  conversationId  String
  summary         String
  keyDecisions    Json     // Array of key decisions made during the conversation
  followUps       Json     // Array of follow-up items identified
  emotionalState  String?
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt       DateTime @default(now())

  @@index([userId, createdAt])
  @@index([conversationId])
  @@map("user_memories")
}

model ChatConversation {
  id                     String                  @id @default(cuid())
  userId                 String?
  guestSessionId         String?
  title                  String
  latestQuestion         String?
  latestAnswer           String?
  metadata               Json?
  medicalExtraction      Json?
  medicalFeatures        Json?
  createdAt              DateTime                @default(now())
  updatedAt              DateTime                @updatedAt
  user                   User?                   @relation(fields: [userId], references: [id], onDelete: SetNull)
  messages               ChatMessage[]
  retrievalHits          ChatRetrievalHit[]

  @@index([userId, updatedAt])
  @@index([guestSessionId, updatedAt])
  @@map("chat_conversations")
}

model ChatMessage {
  id             String            @id @default(cuid())
  conversationId String
  role           String
  content        String
  sequence       Int
  metadata       Json?
  createdAt      DateTime          @default(now())
  conversation   ChatConversation  @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId, sequence])
  @@map("chat_messages")
}

model ChatRetrievalHit {
  id             String            @id @default(cuid())
  conversationId String
  messageId       String?
  title          String
  relativePath   String
  score          Int
  excerpt        String
  metadata       Json?
  createdAt      DateTime          @default(now())
  conversation   ChatConversation  @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId, createdAt])
  @@map("chat_retrieval_hits")
}

model CoverageScore {
  id              String   @id @default(cuid())
  userId          String
  planId          String?
  overallScore    Int      // 0–100 weighted average
  hospital        Int      // 0–100
  prescriptionDrugs Int    // 0–100
  dental          Int      // 0–100
  vision          Int      // 0–100
  mentalHealth    Int      // 0–100
  emergency       Int      // 0–100
  rationale       String?  // LLM-generated explanation
  createdAt       DateTime @default(now())
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@map("coverage_scores")
}

model LifeEvent {
  id          String    @id @default(cuid())
  userId      String
  eventType   String    // job_change, new_baby, marriage, move, birthday, lost_coverage
  description String?
  eventDate   DateTime  @default(now())
  processed   Boolean   @default(false)
  processedAt DateTime?
  createdAt   DateTime  @default(now())
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, processed])
  @@map("life_events")
}

model MedicalShareLink {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([token])
  @@map("medical_share_links")
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([userId, createdAt])
  @@map("password_reset_tokens")
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  type      String   // coverage_gap_alert, life_event_checkin, enrollment_countdown
  title     String
  body      String
  emailSent Boolean  @default(false)
  read      Boolean  @default(false)
  readAt    DateTime?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, read])
  @@index([userId, createdAt])
  @@map("notifications")
}
